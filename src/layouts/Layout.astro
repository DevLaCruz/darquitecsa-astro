---
interface Props {
  title?: string;
}

const { title = "DARQUITECSA" } = Astro.props;
const pathname = new URL(Astro.url).pathname;

const socialLinks = {
  facebook: "https://facebook.com/darquitecsa", 
  instagram: "http://www.instagram.com/darquitecsa"
  // tiktok: "http://www.tiktok.com"
};

// Data actualizada desde tu base de datos para el Footer
const pages = [
  { id: 1, title: "Quienes Somos" },
  { id: 2, title: "Valores" },
  { id: 3, title: "Política de Privacidad" },

];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <title>{title} | DARQUITECSA</title>
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  
  <link href="/img/apple-touch-icon.png" rel="apple-touch-icon">
  <link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/lib/font-awesome/css/font-awesome.min.css" rel="stylesheet">
  <link href="/lib/animate/animate.min.css" rel="stylesheet">
  <link href="/lib/ionicons/css/ionicons.min.css" rel="stylesheet">
  <link href="/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
  <link href="/css/services.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <link href="/css/banner.css" rel="stylesheet">
</head>

<body class="home-page">
  <div class="click-closed"></div>

  <nav class="navbar navbar-default navbar-trans navbar-expand-lg fixed-top">
    <div class="container">
      <button class="navbar-toggler collapsed" type="button" data-toggle="collapse" data-target="#navbarDefault">
        <span></span><span></span><span></span>
      </button>
      <a class="navbar-brand text-brand" href="/">DAR<span class="color-b">QUITECSA</span></a>
      
      <div class="navbar-collapse collapse justify-content-end" id="navbarDefault">
        <ul class="navbar-nav ml-auto">
          <li class="nav-item">
            <a class={`nav-link ${pathname === "/" ? "active" : ""}`} href="/">Inicio</a>
          </li>
          <li class="nav-item">
            <a class={`nav-link ${pathname === "/about" ? "active" : ""}`} href="/about">Nosotros</a>
          </li>
          <li class="nav-item">
            <a class={`nav-link ${pathname === "/services" ? "active" : ""}`} href="/services">Servicios</a>
          </li>
          
          <li class="nav-item">
            <a class={`nav-link ${pathname === "/contact" ? "active" : ""}`} href="/contact">Contacto</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <slot />

  <section class="section-footer">
    <div class="container">
      <div class="row">
        <div class="col-sm-12 col-md-4">
          <div class="widget-a">
            <div class="w-header-a">
              <h3 class="w-title-a text-brand">Darquitecsa</h3>
            </div>
            <div class="w-body-a">
              <p class="w-text-a color-text-a">Excelencia en ingeniería, construcción y diseño.</p>
            </div>
            <div class="w-footer-a">
              <ul class="list-unstyled">
                <li class="color-a"><span class="color-text-a">Email .</span> darquitecsa@gmail.com</li>
                <li class="color-a"><span class="color-text-a">Teléfono .</span> +51 975 535 023</li>
              </ul>
            </div>
          </div>
        </div>
        
        <div class="col-sm-12 col-md-4 section-md-t3">
          <div class="widget-a">
            <div class="w-header-a"><h3 class="w-title-a text-brand">Páginas</h3></div>
            <div class="w-body-a">
              <ul class="list-unstyled">
                {pages.map((page) => (
                  <li class="item-list-a">
                    <i class="fa fa-angle-right"></i> <a href={`/page/${page.id}`}>{page.title}</a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <div class="col-sm-12 col-md-4 section-md-t3">
          <div class="widget-a">
            <div class="w-header-a"><h3 class="w-title-a text-brand">Redes Sociales</h3></div>
            <div class="w-body-a">
              <ul class="list-unstyled">
                {socialLinks.facebook && (
                  <li><i class="fa fa-facebook"></i> <a href={socialLinks.facebook}>Facebook</a></li>
                )}
                {socialLinks.instagram && (
                  <li><i class="fa fa-instagram"></i> <a href={socialLinks.instagram}>Instagram</a></li>
                )}
                <!-- {socialLinks.tiktok && (
                  <li><i class="fa fa-tiktok"></i> <a href={socialLinks.tiktok}>TikTok</a></li>
                )} -->
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <a href="#" class="back-to-top"><i class="fa fa-chevron-up"></i></a>
  <div id="preloader"></div>

  <script is:inline src="/lib/jquery/jquery.min.js"></script>
  <script is:inline src="/lib/jquery/jquery-migrate.min.js"></script>
  <script is:inline src="/lib/popper/popper.min.js"></script>
  <script is:inline src="/lib/bootstrap/js/bootstrap.min.js"></script>
  <script is:inline src="/lib/easing/easing.min.js"></script>
  <script is:inline src="/lib/owlcarousel/owl.carousel.min.js"></script>
  <script is:inline src="/lib/scrollreveal/scrollreveal.min.js"></script>
  <script is:inline src="/js/main.js"></script>
</body>
</html>