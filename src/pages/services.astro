---
// astro_site/src/pages/services.astro
import Layout from '../layouts/Layout.astro';

// 1. SIMULACIÓN DE DATOS (Lo que antes hacía tu views.py)
// Como Astro no lee la base de datos SQLite de Django por defecto, 
// temporalmente definimos los datos aquí. Más adelante puedes 
// traerlos con un fetch() desde una API de Django o un archivo JSON.
const services = [
  {
    id: 1,
    title: "Diseño de muebles",
    subtitle: "Servicios en diseño y fabricación de muebles para el hogar, oficina, industria, etc.",
    content: "Trabajamos con materiales como la melamina, la madera y el MDF, a este último le podemos hacer diseños para posteriormente enchaparlo o pintarlo. Con respecto a encimeras para cocina, trabajamos principalmente con piedras naturales como el granito y el mármol, y con piedras fabricadas como el cuarzo Silestone y la piedra sintetizada ultra compacta Dekton. Además, tienes que saber que trabajamos tu proyecto de manera integral, en cualquier parte del Perú.",
    image: "/public/media/services/mueble.jpg"
  },
  {
    id: 2,
    title: "Modelamiento BIM",
    subtitle: "Nuestra Especialidad",
    content: "Elaboramos modelos BIM, a fin de detectar interferencias de diseño y minimizar tiempo y costo en la etapa de construcción. Los modelos son generados a partir de planos y documentos de ingeniería del cliente. Los modelos 3D se elaboran en software especializado y se realiza la revisión interdisciplinaria, cargando los modelos en un solo archivo central, el cual muestra los detalles constructivos y toda la información de la ingeniería del proyecto.",
    image: "/public/media/services/bim.jpg"
  },
  {
    id: 3,
    title: "Modelado de Proyectos",
    subtitle: "Ofrecemos al mercado civil",
    content: "Brindamos servicios en modelado de proyectos de Infraestructura Civil bajo la aplicación de la metodología BIM. Además, damos alternativas tecnológicas e innovadoras de alto impacto en la eficiencia de colaboración remota que permitirán revolucionar las fases de tu proyecto desde el diseño, la construcción hasta el mantenimiento.",
    image: "/public/media/services/modelado.jpg"
  },
  {
    id: 4,
    title: "Diseño de Interiores",
    subtitle: "Nos especializamos también en",
    content: "Tanto en interiores como exteriores de índole comercial, vivienda (familiar y multifamiliar), religioso, cultural, áreas públicas urbanas (pasajes, boulevard, parques, etc.).",
    image: "/public/media/services/interiores.jpg"
  },
  {
    id: 5,
    title: "Mantenimiento Integral",
    subtitle: "Tenemos experiencia en:",
    content: "Brindamos servicios en general como mantenimiento preventivo en locales públicos y privados, ejecución de trabajos en instalaciones eléctricas, sanitarias, mecánicas y de comunicaciones.",
    image: "/public/media/services/Edificio8.jfif"
  },
  {
    id: 6,
    title: "Ingeniería y Construcción",
    subtitle: "Ofrecemos al mercado servicios de",
    content: "Elaboración de expedientes técnicos de proyectos de ingeniería (Civil, Estructura metálica, Arquitectura, Eléctricas, Sanitaria, Agua contra incendio y HVAC), Construcción Obras públicas o privadas y Desarrollos inmobiliarios.",
    image: "/public/media/services/floor-plan.jpg"
  }
];
---

<Layout title="Servicios">
  
  {services.map((service) => (
    <section id={`service_${service.id}`} class="page-section">
      <div class="container foo">
        <div class="product-item">
          
          <div class="product-item-title item-animation">
            <div class="faded p-5 d-flex mr-auto rounded">
              <h2 class="section-heading mb-0">
                <span class="section-heading-upper">{service.subtitle}</span>
                <span class="section-heading-lower">{service.title}</span>
              </h2>
            </div>
          </div>
          
          <img 
            class="product-item-img mx-auto d-flex rounded img-fluid mb-3 mb-lg-0 item-animation" 
            src={service.image} 
            alt={`Imagen representativa de ${service.title}`} 
          />
          
          <div class="product-item-description d-flex ml-auto item-animation">
            <div class="faded p-5 rounded">
              <p class="mb-0">{service.content}</p>
              <div class="title-link">
  <a href={`/contact?service=${encodeURIComponent(service.title)}`}>
    Contactar Servicio
    <span class="ion-ios-arrow-forward"></span>
  </a>
</div>
            </div>
          </div>
          
        </div>
      </div>
    </section>
  ))}

</Layout>