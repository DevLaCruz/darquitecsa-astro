---
import Layout from '../../layouts/Layout.astro';

// 1. Astro necesita saber qué páginas construir (Rutas Estáticas).
// Aquí ponemos toda la información cruzada de tus proyectos y sus galerías de imágenes.
export async function getStaticPaths() {
  const allProjects = [
    { 
      id: "1", 
      title: "Primer Edificio", 
      description: "<p>It is a long established fact that a reader will be distracted by the readable content of a page when looking at its layout. The point of using Lorem Ipsum is that it has a more-or-less normal distribution of letters, as opposed to using 'Content here, content here', making it look like readable English. Many desktop publishing packages and web page editors now use Lorem Ipsum as their default model text, and a search for 'lorem ipsum' will uncover many web sites still in their infancy. Various versions have evolved over the years, sometimes by accident, sometimes on purpose (injected humour and the like).</p>",
      images: [
        "/media/gallery/Edificio2.jfif", 
        "/media/gallery/Edificio2.1ç.jfif"
      ]
    },
    { 
      id: "2", 
      title: "Dormitoriosfgjgj", 
      description: "<p>sghsrdfjtyktuk7iyuoyoyupyuiryt</p>",
      images: [
        "/media/gallery/img16.jpg", 
        "/media/gallery/img17.jpg", 
        "/media/gallery/img18.jpg", 
        "/media/gallery/img32.jpg", 
        "/media/gallery/img47.jpg", 
        "/media/gallery/img60.jpg", 
        "/media/gallery/img12_Vw01b3B.jpg"
      ]
    },
    { 
      id: "3", 
      title: "Cocinas1", 
      description: "<p>djgffhkdxki7tyityikr6iktit57</p>",
      images: [
        "/media/gallery/img32_DkX86AO.jpg", 
        "/media/gallery/img19.jpg", 
        "/media/gallery/img16_ZH120oI.jpg", 
        "/media/gallery/img45.jpg"
      ]
    },
    { 
      id: "4", 
      title: "modelos", 
      description: "<p>klyguldtyu7otuyorxfytikrftykirfytigygugougffgjfgjfi</p><br><p>gyhkgtaaasfsad</p>",
      images: [
        "/media/gallery/img12.jpg", 
        "/media/gallery/img13.jpg"
      ]
    }
  ];

  return allProjects.map((project) => ({
    params: { id: project.id },
    props: { project }, // Pasamos el proyecto completo como prop a la página
  }));
}

// 2. Extraemos los datos del proyecto actual
const { project } = Astro.props;
---

<Layout title={project.title}>
  <section class="intro-single" style="margin-top: -90px;">
    <div class="container">
      <div class="row">
        <div class="col-md-12 col-lg-8">
          <div class="title-single-box">
            <h1 class="title-single">{project.title}</h1>
          </div>
        </div>
        <div class="col-md-12 col-lg-4">
          <nav aria-label="breadcrumb" class="breadcrumb-box d-flex justify-content-lg-end">
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/">Home</a></li>
              <li class="breadcrumb-item"><a href="/projects">Proyectos</a></li>
              <li class="breadcrumb-item active" aria-current="page">{project.title}</li>
            </ol>
          </nav>
        </div>
      </div>
    </div>
  </section>

  <section class="property-single nav-arrow-b">
    <div class="container">
      <div class="row">
        
        <div class="col-sm-12">
          <div id="property-single-carousel" class="owl-carousel owl-arrow gallery-property">
            {project.images.map((image) => (
              <div class="carousel-item-b">
                <img src={image} alt={`Imagen de ${project.title}`} style="width: 100%; height: auto; max-height: 600px; object-fit: cover;">
              </div>
            ))}
          </div>
        </div>

        <div class="row section-md-t3" style="margin: 11px; width: 100%;">
          
          <div class="col-md-6">
            <div class="title-box-d">
              <h3 class="title-d">Descripción del Proyecto</h3>
            </div>
            <div class="property-description">
              <div class="description color-text-a" set:html={project.description}></div>
            </div>
          </div>
          
          <div class="col-md-6">
            <div class="title-box-d">
              <h3 class="title-d">Consultar por este proyecto</h3>
            </div>
            <div class="property-contact">
              
              <form class="form-a" action="https://formsubmit.co/darquitecsa@gmail.com" method="POST" id="project-contact-form">
                <input type="hidden" name="_subject" value={`Consulta web sobre el proyecto: ${project.title}`}>
                <input type="hidden" name="_captcha" value="false">
                
                <div class="row">
                  <div class="col-md-12 mb-2">
                    <div class="form-group">
                      <input type="text" id="proj-name" name="name" class="form-control form-control-lg form-control-a" placeholder="Tu Nombre *" required>
                    </div>
                  </div>
                  <div class="col-md-12 mb-2">
                    <div class="form-group">
                      <input type="tel" id="proj-phone" name="phone" class="form-control form-control-lg form-control-a" placeholder="Tu Celular *" required>
                    </div>
                  </div>
                  <div class="col-md-12 mb-2">
                    <div class="form-group">
                      <textarea id="proj-message" name="message" class="form-control" placeholder="Escribe tu consulta *" cols="45" rows="5" required></textarea>
                    </div>
                  </div>
                  <div class="col-md-12">
                    <button type="submit" class="btn btn-a">Consultar por WhatsApp y Correo</button>
                  </div>
                </div>
              </form>

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline define:vars={{ projectTitle: project.title }}>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('project-contact-form');

    if(form) {
      form.addEventListener('submit', (e) => {
        const name = document.getElementById('proj-name').value;
        const phone = document.getElementById('proj-phone').value;
        const message = document.getElementById('proj-message').value;

        // Armamos el mensaje para WhatsApp (¡Incluye el título del proyecto!)
        const text = `Hola DARQUITECSA.%0AEstoy viendo su página web y me interesa el proyecto *${projectTitle}*.%0A%0A*Mi nombre:* ${name}%0A*Mi celular:* ${phone}%0A*Consulta:* ${message}`;
        
        const waUrl = `https://wa.me/51975535023?text=${text}`;

        // Abre WhatsApp
        window.open(waUrl, '_blank');
        
        // Continúa y envía el correo por FormSubmit
      });
    }
  });
</script>