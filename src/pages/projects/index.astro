---
import Layout from '../../layouts/Layout.astro';

// Simulamos los datos que enviaba tu vista de Django
const categories = [
  { id: 1, name: "Residencial" },
  { id: 2, name: "Comercial" }
];

const projects = [
  {
    id: 1,
    title: "Primer Edificio",
    image: "/media/gallery/Edificio2.jfif",
    category: "Edificios",
    published: "08 Nov" // Formateado de 2023-11-08
  },
  {
    id: 2,
    title: "Dormitorios",
    image: "/media/gallery/img16.jpg",
    category: "Dormitorios",
    published: "08 Nov" // Formateado de 2023-11-08
  },
  {
    id: 3,
    title: "Cocinas1",
    image: "/media/gallery/img32_DkX86AO.jpg",
    category: "Cocina",
    published: "09 Nov" // Formateado de 2023-11-09
  },
  {
    id: 4,
    title: "modelos",
    image: "/media/gallery/img12.jpg",
    category: "departamento",
    published: "09 Nov" // Formateado de 2023-11-09
  }
];
---

<Layout title="Proyectos">
  <section class="intro-single" style="margin-top: -90px;">
    </section>

  <section class="property-grid grid">
    <div class="container">
      <div class="row">
        {projects.map((project) => (
          <div class="col-md-4">
            <div class="card-box-a card-shadow">
              <div class="img-box-a">
                <img src={project.image} alt={project.title} class="img-a img-fluid">
              </div>
              <div class="card-overlay">
                <div class="card-overlay-a-content">
                  <div class="card-header-a">
                    <h2 class="card-title-a">
                      <a href={`/projects/${project.id}`}>{project.title}</a>
                    </h2>
                  </div>
                  <div class="card-body-a">
                    <a href={`/projects/${project.id}`} class="link-a">
                      Ver detalle <span class="ion-ios-arrow-forward"></span>
                    </a>
                  </div>
                  <div class="card-footer-a">
                    <ul class="card-info d-flex justify-content-around">
                      <li>
                        <h4 class="card-info-title">Categoría</h4>
                        <span>{project.category}</span>
                      </li>
                      <li>
                        <h4 class="card-info-title">Publicado el</h4>
                        <span>{project.published}</span>
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>